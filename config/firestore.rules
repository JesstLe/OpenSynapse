rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Existing Collections: notes, flashcards, chat_sessions
    // ===============================================================
    
    match /notes/{noteId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }

    match /flashcards/{cardId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }

    match /chat_sessions/{sessionId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }

    // ===============================================================
    // NEW: User Profile
    // Collection: users/{firebaseUid}
    // 用户可以读写自己的档案
    // ===============================================================
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }

    // ===============================================================
    // NEW: Custom Personas
    // Collection: custom_personas/{personaId}
    // 用户可以读写自己创建的人格
    // ===============================================================
    match /custom_personas/{personaId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ===============================================================
    // NEW: Connected Accounts (Third-party login mapping)
    // Collection: connected_accounts/{provider}_{providerUserId}
    // 用户只读自己的账号映射，创建/更新/删除由服务端控制
    // ===============================================================
    match /connected_accounts/{accountId} {
      // 用户只能读取关联到自己 firebaseUid 的记录
      allow read: if isAuthenticated() && resource.data.firebaseUid == request.auth.uid;
      // 创建、更新、删除仅允许服务端（通过 Admin SDK 或特定服务账号）
      // 前端不应直接写入此集合
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ===============================================================
    // NEW: Account Secrets (User-level API Keys)
    // Collection: account_secrets/{firebaseUid}
    // ⚠️ 严格限制：仅允许用户自己访问自己的 API Key
    // 服务端通过 Admin SDK 读取，前端只能读写自己的
    // ===============================================================
    match /account_secrets/{uid} {
      // 严格限制：只能访问自己的 API Key
      allow read: if isOwner(uid);
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }

    // ===============================================================
    // NEW: Auth Sessions (Short-term OAuth state)
    // Collection: auth_sessions/{sessionId}
    // 仅服务端读写
    // ===============================================================
    match /auth_sessions/{sessionId} {
      allow read: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
