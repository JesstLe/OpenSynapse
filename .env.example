# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional API keys for non-Gemini providers.
# These models only use API key auth today.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_BASE_URL="https://api.openai.com/v1"
MINIMAX_API_KEY="YOUR_MINIMAX_API_KEY"
MINIMAX_BASE_URL="https://api.minimaxi.com/anthropic"
ZHIPU_API_KEY="YOUR_ZHIPU_API_KEY"
ZHIPU_BASE_URL="https://open.bigmodel.cn/api/anthropic"
MOONSHOT_API_KEY="YOUR_MOONSHOT_API_KEY"
MOONSHOT_BASE_URL="https://api.kimi.com/coding/"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional overrides for Gemini CLI / Code Assist OAuth.
# By default, OpenSynapse will try to extract the bundled client from a local `gemini` install.
OPENSYNAPSE_GEMINI_OAUTH_CLIENT_ID="YOUR_GEMINI_CLI_OAUTH_CLIENT_ID"
OPENSYNAPSE_GEMINI_OAUTH_CLIENT_SECRET="YOUR_GEMINI_CLI_OAUTH_CLIENT_SECRET"

# Optional when your Code Assist account requires a specific project.
GOOGLE_CLOUD_PROJECT="YOUR_GOOGLE_CLOUD_PROJECT_ID"

# Development only. When not set to "0", local dev will bypass Firebase login
# and keep notes / flashcards / chat sessions in memory for faster UI debugging.
VITE_DISABLE_AUTH="1"
