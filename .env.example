# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional API keys for non-Gemini providers.
# These models only use API key auth today.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_BASE_URL="https://api.openai.com/v1"
MINIMAX_API_KEY="YOUR_MINIMAX_API_KEY"
MINIMAX_BASE_URL="https://api.minimaxi.com/anthropic"
ZHIPU_API_KEY="YOUR_ZHIPU_API_KEY"
ZHIPU_BASE_URL="https://open.bigmodel.cn/api/anthropic"
MOONSHOT_API_KEY="YOUR_MOONSHOT_API_KEY"
MOONSHOT_BASE_URL="https://api.kimi.com/coding/"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional overrides for Gemini CLI / Code Assist OAuth.
# By default, OpenSynapse will try to extract the bundled client from a local `gemini` install.
OPENSYNAPSE_GEMINI_OAUTH_CLIENT_ID="YOUR_GEMINI_CLI_OAUTH_CLIENT_ID"
OPENSYNAPSE_GEMINI_OAUTH_CLIENT_SECRET="YOUR_GEMINI_CLI_OAUTH_CLIENT_SECRET"

# Optional when your Code Assist account requires a specific project.
GOOGLE_CLOUD_PROJECT="YOUR_GOOGLE_CLOUD_PROJECT_ID"

# Development only. When not set to "0", local dev will bypass Firebase login
# and keep notes / flashcards / chat sessions in memory for faster UI debugging.
VITE_DISABLE_AUTH="1"

# ============================================
# Multi-Provider Authentication (WeChat / QQ)
# ============================================
# Required for WeChat/QQ OAuth login support
# Register at: https://open.weixin.qq.com/ (微信)
# Register at: https://connect.qq.com/ (QQ)

WECHAT_APP_ID="your_wechat_app_id"
WECHAT_APP_SECRET="your_wechat_app_secret"

QQ_APP_ID="your_qq_app_id"
QQ_APP_SECRET="your_qq_app_secret"

# ============================================
# Firebase Admin SDK (Required for server-side auth)
# ============================================
# Get from Firebase Console → Project Settings → Service Accounts
# This is needed for generating custom tokens for WeChat/QQ login

FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"your-project"}'

# ============================================
# Self-Hosted Database Configuration
# ============================================
# PostgreSQL database URL for self-hosted mode
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://opensynapse:password@localhost:5432/opensynapse"

# JWT Secret for authentication (min 32 characters)
JWT_SECRET="your-super-secret-jwt-key-minimum-32-chars"

# Chroma vector database path
CHROMA_PATH="./data/chroma"

# ============================================
# Commercial Deployment Notes
# ============================================
# For multi-tenant commercial deployments:
# 1. Each user's API keys are stored in Firestore (account_secrets/{uid})
# 2. Global API keys above are used as fallback only
# 3. Users can configure personal API keys in Settings
# See docs/auth/environment-variables.md for full documentation
